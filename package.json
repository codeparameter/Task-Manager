{
  "name": "task-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "dotenv -e .env.prod next build",
    "start": "dotenv -e .env.prod next start",
    "lint": "eslint",
    "migrate:dev": "dotenv -e .env.dev npx prisma migrate dev",
    "migrate:prod": "dotenv -e .env.prod npx prisma migrate deploy",
    "generate": "npx prisma generate",
    "studio": "dotenv -e .env.dev -- prisma studio",
    "up:dev": "podman compose -f compose.yml --env-file .env.dev up -d && podman ps -a",
    "up:prod": "podman compose -f compose.yml --env-file .env.prod up -d && podman ps -a",
    "down:dev": "podman compose -f compose.yml --env-file .env.dev down && podman ps -a",
    "down:prod": "podman compose -f compose.yml --env-file .env.prod down && podman ps -a",
    "containers": "podman ps -a"
  },
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "^4.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv-cli": "^11.0.0",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "postcss": "^8.5.15",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "typescript": "^5"
  }
}
